          <mxGeometry x="560" y="480" width="170" height="60" as="geometry" />
        </mxCell>

        <!-- Add Item to Cart -->
        <mxCell id="add-to-cart" value="User Adds Item to Cart" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" parent="1" vertex="1">
